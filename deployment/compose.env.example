# 複製到專案根目錄並改名為 .env：
#   cp deployment/compose.env.example .env
# （.env 已被 .gitignore，不會被提交）

# 必填：隨機字串，例如 PowerShell: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
# 或：openssl rand -hex 32
WEBUI_SECRET_KEY=change_me_run_openssl_rand_hex_32

# 瀏覽器實際開啟的網址（影響 OAuth、連結、Cookie）
# 直連埠 8080 測試：
WEBUI_URL=http://localhost:8080
# 走 Caddy HTTPS 時改為：
# WEBUI_URL=https://chat.example.com

# docker-compose.https.yml 專用：Caddy 監聽的網域（需 DNS 指向你的 Droplet）
# WEBUI_DOMAIN=chat.example.com

# 選填：對外埠（僅 docker-compose.yml 直連模式）
HOST_PORT=8080

# 選填：映像檔名稱與標籤（要 push 到 Docker Hub / GHCR 時設定）
# OPEN_WEBUI_IMAGE_NAME=你的帳號/open-webui
OPEN_WEBUI_IMAGE_TAG=local

# 選填：具名 volume，方便在多個 stack 區分資料
# OPEN_WEBUI_VOLUME_NAME=open_webui_data

# 選填：建置版本顯示字串
# BUILD_HASH=custom

# 其他 Open WebUI 環境變數可繼續寫在此檔，會一併傳入容器
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434
